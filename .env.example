# Copy this file to .env and fill in your values
# The server reads these at startup via dotenvy

# Google OAuth credentials
# Get these from https://console.cloud.google.com/ → APIs & Services → Credentials
# Create an "OAuth 2.0 Client ID" of type "Web application"
# Add http://localhost:3000/api/auth/google/callback to Authorized redirect URIs
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# Where Google redirects after consent (must match the Google Cloud Console setting)
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# Random secret used to sign JWTs — generate with: openssl rand -hex 32
JWT_SECRET=change-me-to-a-long-random-string

# Server config (optional)
PORT=3000
DATABASE_PATH=engage-server.db
RUST_LOG=engage_server=debug,tower_http=info

# Dev only: redirect OAuth callback to the Vite dev server instead of the engage:// deep-link.
# Set this when running `pnpm tauri dev`. Remove (or leave blank) for production builds.
FRONTEND_URL=http://localhost:1420
